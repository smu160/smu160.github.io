---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "An Optimization Odyssey — a blog by Saveliy Yusufov on high-performance software, Rust, SIMD, and parallel computing." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="mYV1yCVvvR3gCh3W7wl_ruVnMej7bNHmiGqMekheyk4" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 w-full max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
